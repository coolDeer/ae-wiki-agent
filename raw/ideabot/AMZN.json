      {
        "id": "73b49a7996e94182b99b77b65c203fc8",
        "analyst": "ACHOW",
        "analystUserId": "10023",
        "eventTypeCode": 1,
        "field": null,
        "fromValue": null,
        "toValue": null,
        "text": "2026-03-24 Framework for AWS is set where we have four main drivers \n1) ANTH: Model to demand, what we need to solve here is pricing, ramp, and just shape of revenues\n2) OAI: First order impact is to model in $138bn to 2034, but seems to be quite back-ended loaded, second order impact maybe on operational efficiency and what not re: EC\n3) Enterprise demand; this is a meaningful catch-all demand pool and think need to get some visibility here \n4) Legacy AWS: The thinking here is more so on how we track quarterly revenues as the only way I can see right now is to track total AWS power demand, but then we need to get legacy right \n\nRetail side we have first jab but could be better",
        "createBy": "10023",
        "updateBy": "10023",
        "createTime": "2026-03-24 17:12:40",
        "updateTime": "2026-03-24 17:12:40"
