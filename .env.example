# =============================================================================
# ae-wiki-agent 环境变量
# =============================================================================
# 复制为 .env 并填实际值。.env 不要 commit。

# --- Postgres（v2 wiki 主存储）---
DATABASE_URL=postgresql://ae_root:CHANGEME@localhost:54329/ae_wiki

# --- MongoDB（上游 ResearchReportRecord，只读）---
MONGODB_URI=mongodb://USER:PASS@HOST:27017/AUTH_DB
MONGODB_DB=
MONGODB_COLLECTION=ResearchReportRecord

# --- OpenAI（embedding + 兜底 fact 抽取）---
OPENAI_API_KEY=sk-xxx
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
# 本地实验时可以关掉所有 embedding 调用：search 走纯 keyword，
# minion-worker 跳过 embed_chunks（任务留 waiting，开关打开后自动回填）。
# 上线置 false 或删掉本行。
EMBEDDING_DISABLED=false

# --- Anthropic（保留给 Stage 5 Tier C fact 抽取兜底；ingest 主路径不再调 LLM）---
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_FACT_EXTRACT_MODEL=claude-haiku-4-5

# --- 本地路径：raw/ 子目录所在的根（默认 . 即 ae-wiki-agent 项目根）---
WORKSPACE_DIR=.

# --- 可选 ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-1
# LOG_LEVEL=info
