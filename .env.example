# =============================================================================
# ae-wiki-agent 环境变量
# =============================================================================
# 复制为 .env 并填实际值。.env 不要 commit。

# --- Postgres（v2 wiki 主存储）---
DATABASE_URL=postgresql://ae_root:CHANGEME@localhost:54329/ae_wiki

# --- MongoDB（上游 ResearchReportRecord，只读）---
MONGODB_URI=mongodb://USER:PASS@HOST:27017/AUTH_DB
MONGODB_DB=
MONGODB_COLLECTION=ResearchReportRecord

# --- OpenAI（embedding + durable agent runtime + 未来 fact 抽取）---
OPENAI_API_KEY=sk-xxx
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_AGENT_MODEL=gpt-5-mini
OPENAI_FACT_EXTRACT_MODEL=gpt-5-mini
# 本地实验时可以关掉所有 embedding 调用：search 走纯 keyword，
# minion-worker 跳过 embed_chunks（任务留 waiting，开关打开后自动回填）。
# 上线置 false 或删掉本行。
EMBEDDING_DISABLED=false

# --- 本地路径：raw/ 子目录所在的根（默认 . 即 ae-wiki-agent 项目根）---
WORKSPACE_DIR=.

# --- 检索：source-aware ranking ---
# 格式 "prefix1:1.5,prefix2:0.7"，与 src/core/search/source-boost.ts 的 DEFAULT 合并
# WIKI_SOURCE_BOOST=
# 硬排除前缀，逗号分隔：WIKI_SEARCH_EXCLUDE=briefs/,sources/cb-
# WIKI_SEARCH_EXCLUDE=

# --- 检索：多路扩展 + 意图分类（gbrain 风格）---
# 分段：固定走 V2 block-aware chunker（src/core/chunkers/v2-block.ts），
# 不再有 markdown chunker 选项；所有 raw_files 必须有 parsed_content_list_v2_url。
# 多 query 扩展：开启后用 OPENAI_AGENT_MODEL 改写出 2 个备选并召回融合
WIKI_QUERY_EXPANSION=false
# search debug：打印 RRF / cosine / boost 中间值到 stderr
WIKI_SEARCH_DEBUG=false

# --- Worker 可靠性（生产建议）---
# RSS watchdog：worker 进程 RSS 超过此 MB 阈值后优雅退出（让 supervisor 重启进程）。
# 0 = 关（默认）；生产长跑建议 2048。借鉴 gbrain v0.22.2 — 防内存泄漏导致 worker 卡死。
WIKI_WORKER_RSS_LIMIT_MB=0
# DB 连接重试：跳过 connectWithRetry 的 3 次 backoff，遇错立即抛。
# 默认重试，仅在 debug / 一次性脚本时设 1 关闭。
# WIKI_NO_RETRY_CONNECT=1

# --- 可选 ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-1
# LOG_LEVEL=info
